# Server
PORT=8080
LOG_LEVEL=info

# Hugging Face Router secret - ضعها في السيرفر فقط، لا تضعها داخل تطبيق Android.
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_ROUTER_BASE_URL=https://router.huggingface.co/v1

# Google AI Studio secret - يبقى على السيرفر.
GOOGLE_STUDIO_API_KEY=AIza...
GOOGLE_STUDIO_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Tavily secret - لا تضعه داخل Android.
TAVILY_API_KEY=tvly-...
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/

# Cloudinary secrets - تستخدم للرفع من الباك إند فقط.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_FOLDER=chat-ui/kotlin

# Firebase Admin / Google Cloud
FIREBASE_PROJECT_ID=your-firebase-project-id
# للتشغيل المحلي فقط:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-service-account.json

# Security controls
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
REQUEST_TIMEOUT_SECONDS=60
STREAM_TIMEOUT_SECONDS=180
# 0 = no backend prompt-length limit. Provider/model context limits can still apply.
MAX_PROMPT_CHARS=0
MAX_UPLOAD_MB=20
MAX_PDF_UPLOAD_MB=20
MAX_PDF_TEXT_CHARS=60000
RATE_LIMIT_PER_MINUTE=30
